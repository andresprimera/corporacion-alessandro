# Comma-separated list of supported locales. Defaults to "en" when not set.
# When only one locale is configured, the language toggle is hidden.
VITE_SUPPORTED_LOCALES=en,es

# Set to "false" to hide the "Back to home" link on login/signup pages.
# Useful when there is no landing page and login is the entry point.
VITE_LANDING_PAGE=true

# Base URL of the backend API. Leave unset for local dev so calls stay
# relative and go through the Vite dev proxy (vite.config.ts).
# In production set this to the public API origin in .env.production
# (e.g. https://api.example.com).
VITE_API_URL=
